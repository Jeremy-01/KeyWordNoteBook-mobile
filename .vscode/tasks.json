      },
      "problemMatcher": []
    },
    {
      "label": "Mobile: Flutter run (Android USB)",
      "type": "shell",
      "command": "/bin/bash",
      "args": [
        "${workspaceFolder}/scripts/run-mobile-android-usb.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
