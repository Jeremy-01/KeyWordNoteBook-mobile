APP_NAME=KeyWordNoteBook API
APP_VERSION=1.0.0
DEBUG=True

DATABASE_URL=sqlite:///./keybook.db

JWT_SECRET_KEY=generate-a-32-character-minimum-random-string-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

TRUSTED_HOSTS=localhost,127.0.0.1,your-domain.com

RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

ARGON2_MEMORY_COST=131072
ARGON2_TIME_COST=6
ARGON2_PARALLELISM=6
ARGON2_HASH_LEN=64
